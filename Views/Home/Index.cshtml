                                <div class="text-center">
                                    <p class="small text-muted">A confirmation email has been sent to your registered email address.</p>
                                    <button class="btn btn-daraz w-100 rounded-pill" data-bs-dismiss="modal">Continue Shopping</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            const existingModal = document.getElementById('orderSuccessModal');
            if (existingModal) existingModal.remove();
            
            document.body.insertAdjacentHTML('beforeend', modalHtml);
            const modal = new bootstrap.Modal(document.getElementById('orderSuccessModal'));
            modal.show();
            
            document.getElementById('orderSuccessModal').addEventListener('hidden.bs.modal', function() {
                this.remove();
            });
        }

        function updateCartUI() {
            const count = cartItems.reduce((a, b) => a + (b.quantity || 1), 0);
            document.getElementById('cartCount').innerText = count;
            
            const container = document.getElementById('cartItems');
            if (!cartItems || cartItems.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-5">
                        <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
                        <p class="text-muted">Your cart is empty</p>
                        <button class="btn btn-daraz btn-sm mt-2" onclick="toggleCart()">Start Shopping</button>
                    </div>
                `;
                document.getElementById('cartFooter').innerHTML = '';
                return;
            }
            
            container.innerHTML = cartItems.map(c => `
                <div class="d-flex gap-3 border-bottom pb-3 mb-3">
                    <img src="${c.product?.imageUrl || 'https://placehold.co/70x70/f85606/white?text=Product'}" width="70" height="70" class="rounded-3" style="object-fit:cover" onerror="this.src='https://placehold.co/70x70/f85606/white?text=Product'">
                    <div class="flex-grow-1">
                        <h6 class="mb-1 fw-semibold">${c.product?.title?.substring(0, 40) || 'Product'}</h6>
                        <div class="text-orange fw-bold mb-2">Rs. ${(c.product?.price || 0).toLocaleString()}</div>
                        <div class="d-flex align-items-center gap-2">
                            <button class="quantity-btn" onclick="updateCartQuantityDB(${c.id}, ${(c.quantity || 1) - 1})">-</button>
                            <span class="fw-semibold text-center" style="width: 35px;">${c.quantity || 1}</span>
                            <button class="quantity-btn" onclick="updateCartQuantityDB(${c.id}, ${(c.quantity || 1) + 1})">+</button>
                            <button class="btn btn-sm btn-outline-danger ms-auto rounded-circle" onclick="removeCartItem(${c.id})" style="width: 32px; height: 32px;">
                                <i class="fas fa-trash-alt fa-xs"></i>
                            </button>
                        </div>
                    </div>
                </div>
            `).join('');
            
            const total = cartItems.reduce((s, i) => s + ((i.product?.price || 0) * (i.quantity || 1)), 0);
            const itemCount = cartItems.reduce((s, i) => s + (i.quantity || 1), 0);
            
            document.getElementById('cartFooter').innerHTML = `
                <div class="bg-light p-3 rounded-3 mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Items (${itemCount}):</span>
                        <span>Rs. ${total.toLocaleString()}</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Shipping:</span>
                        <span class="text-success">Free</span>
                    </div>
                    <hr class="my-2">
                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>Total:</span>
                        <span class="text-orange">Rs. ${total.toLocaleString()}</span>
                    </div>
                </div>
                <button class="btn btn-daraz w-100 py-2 rounded-pill fw-bold" onclick="checkout()">
                    <i class="fas fa-credit-card me-2"></i>Proceed to Checkout
                </button>
                <button class="btn btn-outline-secondary w-100 mt-2 rounded-pill" onclick="toggleCart()">
                    Continue Shopping
                </button>
            `;
        }

        // ========== ADMIN FUNCTIONS ==========
        
        async function renderAdminTable() {
            const tbody = document.getElementById('adminTableBody');
            if (!tbody) return;
            document.getElementById('adminTotalCount').innerHTML = `${products.length} items`;
            tbody.innerHTML = products.map(p => `
                <tr>
                    <td><img src="${p.imageUrl || 'https://placehold.co/50x50/f85606/white?text=Img'}" width="50" height="50" style="object-fit:cover"></td>
                    <td style="font-size:13px;">${p.title.substring(0, 35)}</td>
                    <td>${p.category}</td>
                    <td class="text-orange fw-bold">Rs.${(p.price).toLocaleString()}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1 rounded-pill" onclick="loadProductIntoForm(${p.id})"><i class="fas fa-edit"></i></button>
                        <button class="btn btn-sm btn-outline-danger rounded-pill" onclick="deleteProductNode(${p.id})"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            `).join('');
        }

        async function handleFormSubmission(e) {
            e.preventDefault();
            const id = document.getElementById('crudProductId').value;
            const product = {
                title: document.getElementById('crudTitle').value,
                category: document.getElementById('crudCategory').value,
                price: parseFloat(document.getElementById('crudPrice').value),
                imageUrl: document.getElementById('crudImg').value || 'https://placehold.co/400x300/f85606/white?text=Product'
            };
            
            try {
                if (id) {
                    await fetch(`/api/Product/${id}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(product)
                    });
                    showToast("✅ Product updated");
                } else {
                    await fetch('/api/Product', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(product)
                    });
                    showToast("✅ New product added");
                }
                clearCrudForm();
                await loadProductsFromDB();
            } catch(e) {
                showToast("Error saving product");
            }
        }

        async function deleteProductNode(id) {
            if (confirm('Delete this product?')) {
                try {
                    await fetch(`/api/Product/${id}`, { method: 'DELETE' });
                    showToast("🗑️ Product deleted");
                    await loadProductsFromDB();
                } catch(e) {
                    showToast("Error deleting product");
                }
            }
        }

        function loadProductIntoForm(id) {
            const p = products.find(p => p.id === id);
            if (p) {
                document.getElementById('crudProductId').value = p.id;
                document.getElementById('crudTitle').value = p.title;
                document.getElementById('crudCategory').value = p.category;
                document.getElementById('crudPrice').value = p.price;
                document.getElementById('crudImg').value = p.imageUrl || '';
                document.getElementById('formActionTitle').innerHTML = '<i class="fas fa-pen me-2"></i>Edit Product';
                document.getElementById('submitBtnText').innerText = 'Update';
            }
        }

        function clearCrudForm() {
            document.getElementById('productCrudForm').reset();
            document.getElementById('crudProductId').value = '';
            document.getElementById('formActionTitle').innerHTML = '<i class="fas fa-plus-circle me-2"></i>Add New Product';
            document.getElementById('submitBtnText').innerText = 'Save';
        }

        // ========== AUTH FUNCTIONS ==========
        
        async function checkAuth() {
            try {
                const response = await fetch('/api/Auth/check');
                if (response.ok) {
                    currentUser = await response.json();
                    updateAuthWidget();
                    await loadCartFromDB();
                }
            } catch(e) {
                console.log('Not logged in');
            }
        }

        async function executeRegister(e) {
            e.preventDefault();
            const data = {
                name: document.getElementById('regName').value,
                email: document.getElementById('regEmail').value,
                password: document.getElementById('regPass').value,
                role: document.getElementById('regRole').value
            };
            
            try {
                const response = await fetch('/api/Auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                if (response.ok) {
                    showToast(result.message);
                    currentUser = { name: result.name, role: result.role };
                    updateAuthWidget();
                    authModal.hide();
                    await loadCartFromDB();
                } else {
                    showToast(result.message);
                }
            } catch(e) {
                showToast("Registration error");
            }
        }

        async function executeLogin(e) {
            e.preventDefault();
            const data = {
                email: document.getElementById('loginEmail').value,
                password: document.getElementById('loginPass').value
            };
            
            try {
                const response = await fetch('/api/Auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                if (response.ok) {
                    showToast(result.message);
                    currentUser = { name: result.name, role: result.role };
                    updateAuthWidget();
                    authModal.hide();
                    await loadCartFromDB();
                } else {
                    showToast(result.message);
                }
            } catch(e) {
                showToast("Login error");
            }
        }

        async function handleLogout() {
            await fetch('/api/Auth/logout', { method: 'POST' });
            currentUser = null;
            updateAuthWidget();
            showToast("Logged out successfully.");
            document.getElementById('adminControlDashboardView')?.classList.add('d-none');
            document.getElementById('customerMarketplaceView')?.classList.remove('d-none');
            await loadCartFromDB();
        }

        function updateAuthWidget() {
            const w = document.getElementById('authTopWidget');
            if (currentUser) {
                w.innerHTML = `<span class="me-2">👋 Welcome, ${currentUser.name}</span>
                              <a href="#" onclick="handleLogout()" class="text-danger fw-bold ms-2"><i class="fas fa-sign-out-alt"></i> Logout</a>`;
            } else {
                w.innerHTML = `<a href="#" onclick="openAuthModal()" class="fw-bold"><i class="fas fa-key me-1"></i> Login / Signup</a>`;
            }
        }

        function checkAdminAccess() {
            if (!currentUser) { showToast("Please login first!"); openAuthModal(); return; }
            if (currentUser.role !== 'ADMIN') { showToast("❌ Admin access required! Sign up as Administrator."); return; }
            switchToAdminView(true);
        }

        function switchToAdminView(show) {
            if (show) {
                document.getElementById('activeAdminDisplay').innerHTML = currentUser.name;
                document.getElementById('customerMarketplaceView').classList.add('d-none');
                document.getElementById('headerSearchWrapper').classList.add('d-none');
                document.getElementById('cartActionIcon').classList.add('d-none');
                document.getElementById('adminControlDashboardView').classList.remove('d-none');
                renderAdminTable();
            } else {
                document.getElementById('adminControlDashboardView').classList.add('d-none');
                document.getElementById('customerMarketplaceView').classList.remove('d-none');
                document.getElementById('headerSearchWrapper').classList.remove('d-none');
                document.getElementById('cartActionIcon').classList.remove('d-none');
                renderMarketplaceProducts(getFilteredProducts());
            }
        }

        // ========== UI FUNCTIONS ==========
        
        function filterCategory(cat) {
            activeFilter = cat;
            document.querySelectorAll('.category-item').forEach(el => el.classList.remove('active'));
            event.currentTarget.classList.add('active');
            const displayName = cat === 'All' ? 'Featured Products' : cat;
            document.getElementById('sectionTitle').innerHTML = `<i class="fas fa-tag text-orange me-2"></i>${displayName}`;
            renderMarketplaceProducts(getFilteredProducts());
        }

        function filterProductsBySearch() {
            renderMarketplaceProducts(getFilteredProducts());
        }

        function toggleCart() {
            document.getElementById('cartSidebar').classList.toggle('open');
            document.getElementById('cartOverlay').classList.toggle('open');
        }

        function showToast(msg) {
            const t = document.getElementById('toastMsg');
            t.innerText = msg;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 3000);
        }

        function toggleChatbot() { document.getElementById('chatbotWindow').classList.toggle('open'); }

        function sendChatbotMessage() {
            const inp = document.getElementById('chatbotInput'), msg = inp.value.trim();
            if (!msg) return;
            appendChat(msg, 'user-msg');
            inp.value = '';
            setTimeout(() => {
                let reply = "🛍️ Welcome to Daraz Ultimate! We have 88+ products across 9 categories. You can add items to cart, update quantities, and checkout securely!";
                if (msg.toLowerCase().includes('electronic')) reply = "📱 We have iPhones, Samsung, MacBooks, iPads, Sony Headphones, Apple Watches, and more!";
                else if (msg.toLowerCase().includes('fashion')) reply = "👕 Fashion items: Nike Shoes, Adidas, Levi's Jeans, Ray-Ban Sunglasses, Michael Kors Handbags!";
                else if (msg.toLowerCase().includes('cart')) reply = "🛒 Your cart saves to database! You can update quantities, remove items, and checkout securely.";
                else if (msg.toLowerCase().includes('admin')) reply = "🔐 Admin panel requires login with Administrator account. Sign up as Administrator first!";
                else if (msg.toLowerCase().includes('payment')) reply = "💳 Payment is in test mode. Any card details work for testing purposes.";
                appendChat(reply, 'bot-msg');
            }, 300);
        }

        function appendChat(txt, cls) {
            const div = document.createElement('div');
            div.className = `chat-msg ${cls}`;
            div.innerHTML = txt;
            document.getElementById('chatbotMessages').appendChild(div);
            div.scrollIntoView({ behavior: 'smooth' });
        }

        function openAuthModal() { authModal.show(); }
        function switchToRegister() { document.getElementById('loginFormSegment').classList.add('d-none'); document.getElementById('registerFormSegment').classList.remove('d-none'); }
        function switchToLogin() { document.getElementById('registerFormSegment').classList.add('d-none'); document.getElementById('loginFormSegment').classList.remove('d-none'); }

        // ========== INITIALIZE ==========
        document.addEventListener("DOMContentLoaded", () => {
            authModal = new bootstrap.Modal(document.getElementById('authModal'));
            paymentModal = new bootstrap.Modal(document.getElementById('paymentModal'));
            checkAuth();
            loadProductsFromDB();
        });

        // Make functions global
        window.filterProductsBySearch = filterProductsBySearch;
        window.filterCategory = filterCategory;
        window.addToCartDB = addToCartDB;
        window.toggleCart = toggleCart;
        window.switchToAdminView = switchToAdminView;
        window.handleFormSubmission = handleFormSubmission;
        window.loadProductIntoForm = loadProductIntoForm;
        window.deleteProductNode = deleteProductNode;
        window.clearCrudForm = clearCrudForm;
        window.openAuthModal = openAuthModal;
        window.executeLogin = executeLogin;
        window.executeRegister = executeRegister;
        window.handleLogout = handleLogout;
        window.sendChatbotMessage = sendChatbotMessage;
        window.toggleChatbot = toggleChatbot;
        window.checkAdminAccess = checkAdminAccess;
        window.switchToRegister = switchToRegister;
        window.switchToLogin = switchToLogin;
        window.removeCartItem = removeCartItem;
        window.checkout = checkout;
        window.processPayment = processPayment;
        window.updateCartQuantityDB = updateCartQuantityDB;
    </script>
</body>
</html>