        // ========== PRODUCT FUNCTIONS ==========
        
        async function loadProductsFromDB() {
            try {
                // First try to load from database
                const response = await fetch('/api/Product');
                if (response.ok && response.status !== 204) {
                    const dbProducts = await response.json();
                    if (dbProducts && dbProducts.length > 0) {
                        products = dbProducts;
                    } else {
                        // If database empty, use local data and seed
                        products = allProductsData;
                        await seedProductsToDB();
                    }
                } else {
                    products = allProductsData;
                    await seedProductsToDB();
                }
                document.getElementById('totalProductsCount').innerText = products.length;
                renderMarketplaceProducts(getFilteredProducts());
                renderAdminTable();
            } catch(e) {
                console.log('Using local products:', e);
                products = allProductsData;
                renderMarketplaceProducts(getFilteredProducts());
                renderAdminTable();
            }
        }

        async function seedProductsToDB() {
            for (const product of allProductsData) {
                try {
                    await fetch('/api/Product', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(product)
                    });
                } catch(e) {
                    console.log('Error seeding product:', product.title);
                }
            }
        }

        function getFilteredProducts() {
            let filtered = products;
            if (activeFilter !== 'All') {
                filtered = products.filter(p => p.category === activeFilter);
            }
            const search = document.getElementById('searchField')?.value.toLowerCase() || '';
            if (search) {
                filtered = filtered.filter(p => p.title.toLowerCase().includes(search));
            }
            return filtered;
        }

        function renderMarketplaceProducts(items) {
            const container = document.getElementById('productContainer');
            if (!items || items.length === 0) {
                container.innerHTML = '<div class="text-center py-5">No products found</div>';
                return;
            }
            container.innerHTML = items.map(p => `
                <div class="product-card">
                    <img src="${p.imageUrl || p.img || 'https://placehold.co/400x300/f85606/white?text=Product'}" class="product-img" onerror="this.src='https://placehold.co/400x300/f85606/white?text=Product'">
                    <div class="p-3">
                        <span class="small text-orange fw-bold">${p.category}</span>
                        <h6 class="mt-1 fw-semibold" style="font-size:13px;">${p.title.substring(0, 40)}</h6>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="fw-bold text-dark fs-5">Rs. ${(p.price).toLocaleString()}</span>
                            <button class="btn btn-daraz btn-sm py-1 px-3 rounded-pill" onclick="addToCartDB(${p.id})"><i class="fas fa-cart-plus"></i> Add</button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // ========== CART FUNCTIONS (DATABASE) ==========
        
        async function loadCartFromDB() {
            try {
                const response = await fetch('/api/Cart');
                if (response.ok) {
                    cartItems = await response.json();
                    updateCartUI();
                }
            } catch(e) {
                console.log('Error loading cart:', e);
            }
        }

        async function addToCartDB(productId, quantity = 1) {
            if (!currentUser) {
                showToast("Please login first!");
                openAuthModal();
                return;
            }
            
            try {
                const response = await fetch('/api/Cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: productId, quantity: quantity })
                });
                const result = await response.json();
                if (response.ok) {
                    showToast(result.message || "🛒 Added to cart!");
                    await loadCartFromDB();
                } else {
                    showToast(result.message || "Error adding to cart");
                }
            } catch(e) {
                showToast("Error adding to cart");
            }
        }

        async function updateCartQuantityDB(cartId, newQuantity) {
            if (newQuantity < 1) {
                await removeCartItem(cartId);
                return;
            }
            
            try {
                const response = await fetch('/api/Cart/update', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cartId: cartId, quantity: newQuantity })
                });
                if (response.ok) {
                    await loadCartFromDB();
                }
            } catch(e) {
                showToast("Error updating quantity");
            }
        }

        async function removeCartItem(cartId) {
            try {
                const response = await fetch(`/api/Cart/remove/${cartId}`, {
                    method: 'DELETE'
                });
                if (response.ok) {
                    showToast("Item removed from cart");
                    await loadCartFromDB();
                }
            } catch(e) {
                showToast("Error removing item");
            }
        }

        async function checkout() {
            if (!currentUser) {
                showToast("Please login first!");
                openAuthModal();
                return;
            }
            
            if (cartItems.length === 0) {
                showToast("Cart is empty!");
                return;
            }
            
            currentCheckoutCart = [...cartItems];
            const total = cartItems.reduce((s, i) => s + ((i.product?.price || 0) * (i.quantity || 1)), 0);
            
            const orderSummaryHtml = currentCheckoutCart.map(item => `
                <div class="d-flex justify-content-between mb-2">
                    <span>${item.product?.title?.substring(0, 35)} x ${item.quantity}</span>
                    <span>Rs. ${((item.product?.price || 0) * item.quantity).toLocaleString()}</span>
                </div>
            `).join('');
            
            document.getElementById('paymentOrderSummary').innerHTML = `
                <div class="fw-bold mb-2"><i class="fas fa-receipt me-1"></i>Order Summary:</div>
                ${orderSummaryHtml}
                <hr class="my-2">
                <div class="d-flex justify-content-between fw-bold">
                    <span>Total:</span>
                    <span class="text-orange">Rs. ${total.toLocaleString()}</span>
                </div>
            `;
            document.getElementById('paymentAmount').innerHTML = `Rs. ${total.toLocaleString()}`;
            paymentModal.show();
        }

        async function processPayment(e) {
            e.preventDefault();
            
            const cardNum = document.getElementById('cardNumber').value;
            const expiry = document.getElementById('cardExpiry').value;
            const cvv = document.getElementById('cardCvv').value;
            const cardName = document.getElementById('cardName').value;
            
            if (!cardNum || !expiry || !cvv || !cardName) { 
                showToast("Please fill all card details!"); 
                return; 
            }
            
            try {
                const checkoutData = {
                    paymentMethod: "Credit Card",
                    cardLast4: cardNum.slice(-4),
                    totalAmount: cartItems.reduce((s, i) => s + ((i.product?.price || 0) * (i.quantity || 1)), 0),
                    items: cartItems.map(i => ({
                        productId: i.productId,
                        productName: i.product?.title,
                        price: i.product?.price,
                        quantity: i.quantity
                    }))
                };
                
                const response = await fetch('/api/Cart/checkout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(checkoutData)
                });
                const result = await response.json();
                
                if (response.ok) {
                    document.getElementById('cardNumber').value = '';
                    document.getElementById('cardExpiry').value = '';
                    document.getElementById('cardCvv').value = '';
                    document.getElementById('cardName').value = '';
                    paymentModal.hide();
                    toggleCart();
                    
                    showOrderSuccess(result.orderId, result.orderNumber, result.totalAmount, result.orderItems);
                    await loadCartFromDB();
                } else {
                    showToast(result.message || "Checkout failed");
                }
            } catch(e) {
                showToast("Error during checkout");
            }
        }

