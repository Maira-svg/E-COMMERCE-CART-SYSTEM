@{
    ViewData["Title"] = "Admin Terminal Access";
}

<div class="d-flex justify-content-center align-items-center my-5 py-5">
    <div class="card glass-card p-5 shadow-lg text-white w-100" style="max-width: 440px;">
        <div class="text-center mb-4">
            <div class="d-inline-block bg-info text-dark p-3 rounded-circle mb-3 shadow" style="width: 55px; height: 55px; line-height: 25px;">
                🔑
            </div>
            <h3 class="fw-bold m-0">Secure Gateway</h3>
            <p class="text-muted small">Authorized System Operators Only</p>
        </div>

        <form>
            <div class="mb-4">
                <label class="form-label text-muted small fw-semibold">Operator Handle</label>
                <input type="text" class="form-control bg-dark border-secondary text-white rounded-3 py-2 px-3 shadow-sm" style="border-color: rgba(255,255,255,0.12) !important;" placeholder="admin@@shopsmart.com" required>
            </div>
            <div class="mb-4">
                <label class="form-label text-muted small fw-semibold">Security Token Key</label>
                <input type="password" class="form-control bg-dark border-secondary text-white rounded-3 py-2 px-3 shadow-sm" style="border-color: rgba(255,255,255,0.12) !important;" placeholder="••••••••" required>
            </div>
            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-neon w-100 py-2.5 mt-2 text-center text-decoration-none d-block">Access Console</a>
        </form>
    </div>
</div>