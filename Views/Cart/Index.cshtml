@{
    ViewData["Title"] = "Your Shopping Cart";
}

<div class="container my-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-card p-4 shadow-lg text-white mb-4">
                <h3 class="fw-bold mb-4 border-bottom border-secondary pb-3">Your Basket 🛒</h3>

                <div class="d-flex flex-column flex-md-row align-items-center justify-content-between py-3 border-bottom border-muted">
                    <div class="d-flex align-items-center mb-3 mb-md-0">
                        <img src="https://images.unsplash.com/photo-1606144042614-b2417e99c4e3?w=150" class="rounded-3 me-3 object-fit-cover" style="width: 80px; height: 80px;" alt="Product">
                        <div>
                            <h6 class="fw-bold m-0">Pro Tactile Controller</h6>
                            <small class="text-muted">Batch Node #232201</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-4">
                        <div class="text-muted">Qty: <span class="text-white fw-bold">1</span></div>
                        <span class="fw-bold text-info">$199.99</span>
                        <button class="btn btn-sm btn-outline-danger border-0">✕</button>
                    </div>
                </div>
            </div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light rounded-pill px-4">← Continue Shopping</a>
        </div>

        <div class="col-lg-4">
            <div class="glass-card p-4 shadow-lg text-white">
                <h4 class="fw-bold mb-4">Order Summary</h4>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Subtotal</span>
                    <span>$199.99</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Shipping Charges</span>
                    <span class="text-success">Complimentary</span>
                </div>
                <hr class="bg-secondary">
                <div class="d-flex justify-content-between mb-4">
                    <span class="fw-bold fs-5">Total Matrix</span>
                    <span class="fw-bold fs-5 text-glow-neon text-info">$199.99</span>
                </div>
                <button class="btn btn-neon w-100 py-3">Proceed to Checkout</button>
            </div>
        </div>
    </div>
</div>